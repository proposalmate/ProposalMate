[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/proposalmate/proposalmate.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "master"]
	remote = origin
	merge = refs/heads/master
[branch "restructure"]
	remote = origin
	merge = refs/heads/restructure
[branch "main"]
	remote = origin
	merge = refs/heads/main
